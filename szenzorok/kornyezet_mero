#include "Arduino_SensorKit.h"
#define Environment Environment_I2C

int light_sensor = A3;

void setup() {
  Wire.begin();
  Serial.begin(9600);
  Environment.begin();
  Pressure.begin();
}

void loop() {
  int raw_light = analogRead(light_sensor);
  int light = map(raw_light, 0, 1023, 0, 100);

  Serial.print("Light level: ");
  Serial.print(light); // print the light value in Serial Monitor
  Serial.print("   Temperature = ");
  Serial.print(Environment.readTemperature()); //print temperature
  Serial.print(" C  ");
  Serial.print("Humidity = ");
  Serial.print(Environment.readHumidity()); //print humidity
  Serial.print(" %   ");
  Serial.print("Temp2: ");
  Serial.print(Pressure.readTemperature());
  Serial.print("C   "); // The unit for  Celsius because        original arduino don't support speical symbols
  Serial.print("Pressure: ");
  Serial.print(Pressure.readPressure());
  Serial.println("Pa");
  Serial.print("Altitude: ");
  Serial.print(Pressure.readAltitude());
  Serial.println("m");
  delay(2000);
}
